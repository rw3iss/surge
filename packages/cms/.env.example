# Frontend (Vite) dev-server config. Copy to `.env` to override per site.
# These only affect `pnpm dev` (the dev server + API proxy); production builds
# are served from the same origin as the backend and ignore them.

# Port the Vite dev server binds to.
CMS_PORT=3000

# Backend origin that /api, /uploads, /avatars, /sitemap.xml, /feed.xml and
# /robots.txt are proxied to. Must match this site's backend PORT
# (packages/api/.env). Run two sites side by side by giving each its own
# CMS_PORT + CMS_API_TARGET (and a distinct backend PORT).
CMS_API_TARGET=http://localhost:3001
