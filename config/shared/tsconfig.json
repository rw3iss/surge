{
  "compilerOptions": {
    "target": "ES2022",
    // node16 (with no "type":"module" in package.json) emits CommonJS, which
    // resolves the barrel's directory re-exports (`export * from './api'`)
    // natively under raw Node — so @sitesurge/types is Node-loadable, not just
    // bundler-loadable, and the CJS api server can run `node dist` (no tsx).
    "module": "node16",
    "moduleResolution": "node16",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "../../packages/shared/dist",
    "rootDir": "../../packages/shared/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": ["../../packages/shared/src/**/*"],
  "exclude": ["../../packages/shared/node_modules", "../../packages/shared/dist"]
}
